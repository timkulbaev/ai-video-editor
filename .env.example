# AI Video Editor — Environment Variables
#
# Copy this file to .env and fill in your values.
# The tool reads this file automatically if present in the project root.

# OpenRouter API key — required for smart hook + chapter generation.
# If not set, those two steps are skipped with a warning; core editing works offline.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: shown in OpenRouter usage dashboard (HTTP-Referer header).
# Set to your own repo URL or app name for attribution tracking.
OPENROUTER_REFERER=https://github.com/your-username/ai-video-editor
